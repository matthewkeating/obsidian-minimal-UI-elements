{
  "name": "view-actions-mover",
  "version": "1.0.0",
  "description": "Obsidian plugin that moves view-actions into the tab header",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "0.25.3",
    "obsidian": "latest",
    "tslib": "2.8.1",
    "typescript": "5.7.3"
  }
}
